{
  "name": "ohmytrends",
  "version": "0.1.0",
  "private": false,
  "description": "Bun API / CLI for querying Google Trends and Baidu Index",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "bin": {
    "ohmytrends": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --compile --minify --external chromium-bidi --outfile ./bin/ohmytrends",
    "ci": "bun run typecheck && bun test",
    "dev": "OHMYTRENDS_LANG=zh bun src/cli.ts",
    "dev:debug": "OHMYTRENDS_LANG=zh OHMYTRENDS_HEADLESS=false OHMYTRENDS_KEEP_OPEN=true bun src/cli.ts",
    "get": "bun src/cli.ts get",
    "prepack": "bun run ci",
    "release:check": "bun run build && bun pm pack --dry-run",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit"
  },
  "files": [
    "src",
    "docs",
    "schemas",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "examples"
  ],
  "keywords": [
    "baidu-index",
    "google-trends",
    "trends",
    "cli",
    "cloakbrowser"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "cloakbrowser": "^0.3.26",
    "elysia": "^1.4.28",
    "figlet": "^1.11.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.0.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
