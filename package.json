{
  "name": "ohmytrends",
  "version": "0.1.0",
  "private": false,
  "description": "Bun API / CLI for querying Google Trends and Baidu Index",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "homepage": "https://github.com/iswangwenbin/ohmytrends#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/iswangwenbin/ohmytrends.git"
  },
  "bugs": {
    "url": "https://github.com/iswangwenbin/ohmytrends/issues"
  },
  "bin": {
    "ohmytrends": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun run build:css && bun build ./src/cli.ts --compile --minify --external chromium-bidi --outfile ./bin/ohmytrends",
    "build:css": "tailwindcss --input ./src/tailwind.css --output ./src/generated/tailwind.css --minify",
    "ci": "bun run build:css && bun run typecheck && bun test",
    "dev": "OHMYTRENDS_LANG=zh OHMYTRENDS_GOOGLE_MODE=page bun src/cli.ts",
    "dev:debug": "OHMYTRENDS_LANG=zh OHMYTRENDS_GOOGLE_MODE=page OHMYTRENDS_HEADLESS=false OHMYTRENDS_KEEP_OPEN=true bun src/cli.ts",
    "get": "bun src/cli.ts get",
    "prepack": "bun run ci",
    "release:check": "bun scripts/release-check.ts && bun run build && bun pm pack --dry-run",
    "start": "bun src/cli.ts serve",
    "test": "bun test",
    "typecheck": "bun x tsc --noEmit"
  },
  "files": [
    "src",
    "docs",
    "schemas",
    "scripts",
    "README.md",
    "README.zh-CN.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "examples"
  ],
  "keywords": [
    "baidu-index",
    "google-trends",
    "trends",
    "cli",
    "cloakbrowser"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@floating-ui/dom": "^1.7.6",
    "cloakbrowser": "^0.3.31",
    "elysia": "^1.4.28",
    "figlet": "^1.11.0",
    "playwright-core": "^1.60.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.0.0",
    "bun-types": "^1.3.11",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}
